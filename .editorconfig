# http://editorconfig.org
root = true

# Настройки по умолчанию для всех типов файлов
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Специфичные настройки для Bash/Zsh скриптов
[*.{sh,zsh,bash,functions,anobirc}]
indent_style = space
indent_size = 4

# Настройки для конфигурационных файлов JSON/YAML (если появятся)
[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

# Настройки для документации Markdown
[*.md]
trim_trailing_whitespace = false
